# ── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_DRIFT_SIGNALS_TOPIC=feature.drift.signals
DRIFT_CONSUMER_GROUP=drift-monitor

# ── Baseline store ──────────────────────────────────────────────────────────
# backend: "file" (dev) or "minio" (production)
BASELINE_BACKEND=file
BASELINE_PATH_OR_BUCKET=/tmp/drift-baseline.json
BASELINE_WARMUP_WINDOWS=5

# Exponential moving average alpha for gradual baseline adaptation (0 = frozen, 1 = no memory)
BASELINE_EMA_ALPHA=0.05
# Apply EMA update every N consecutive OK windows
BASELINE_EMA_UPDATE_INTERVAL=10

# ── MinIO (only used when BASELINE_BACKEND=minio) ──────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Alerting ────────────────────────────────────────────────────────────────
# Optional HTTP webhook to receive WARNING/ALERT payloads (e.g. Slack incoming webhook)
DRIFT_WEBHOOK_URL=
DRIFT_WEBHOOK_TIMEOUT_SEC=5

# ── Observability ───────────────────────────────────────────────────────────
PROMETHEUS_PORT=8000
LOG_LEVEL=INFO
